# Environment Configuration (development | production | test)
ENVIRONMENT=development
LOG_LEVEL=INFO
SCHEDULER_INTERVAL_SECONDS=5

# API Server Configuration
API_HOST=0.0.0.0
API_PORT=8000

# ==========================================
# PRODUCTION REQUIRED SECRETS
# Do not commit real values to version control
# ==========================================

# Angel One Market Data API
ANGEL_ONE_API_KEY=production_api_key_here
ANGEL_ONE_CLIENT_ID=production_client_id_here
ANGEL_ONE_PASSWORD=production_password_here

# Persistence & Storage
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_production_supabase_key
DATABASE_URL=postgresql+asyncpg://user:password@production-db-host:5432/postgres

# Internal Security
JWT_SECRET=generate_a_secure_random_string_here
INTERNAL_API_TOKEN=generate_a_secure_random_string_here
